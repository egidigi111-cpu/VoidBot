STAFF_ROLE_ID=ROLLE_ID_DES_STAFF_TEAMS
CLOSED_CATEGORY_ID=KATEGORIE_ID_FUER_GESCHLOSSENE_TICKETS

# Welcome/Leave
WELCOME_CHANNEL_ID=WILLKOMMENS_KANAL_ID
